    plotSignalBox(signalLongEntry15mLow1, signalLongEntry15mHigh1, "Long", is15m, 0)
if not na(signalLongEntry15mLow2) and not na(signalLongEntry15mHigh2)
    plotSignalBox(signalLongEntry15mLow2, signalLongEntry15mHigh2, "Long", is15m, 0.5)
if not na(signalLongEntry15mLow3) and not na(signalLongEntry15mHigh3)
    plotSignalBox(signalLongEntry15mLow3, signalLongEntry15mHigh3, "Long", is15m, 1)
if not na(signalLongEntry15mLow4) and not na(signalLongEntry15mHigh4)
    plotSignalBox(signalLongEntry15mLow4, signalLongEntry15mHigh4, "Long", is15m, 1.5)
if not na(signalLongEntry15mLow5) and not na(signalLongEntry15mHigh5)
    plotSignalBox(signalLongEntry15mLow5, signalLongEntry15mHigh5, "Long", is15m, 2)

if not na(signalShortEntry15mLow1) and not na(signalShortEntry15mHigh1)
    plotSignalBox(signalShortEntry15mLow1, signalShortEntry15mHigh1, "Short", is15m, 0)
if not na(signalShortEntry15mLow2) and not na(signalShortEntry15mHigh2)
