// Alert conditions
alertcondition(
    is15mLong1 or is15mLong2 or is15mLong3 or is15mLong4 or is15mLong5 or 
    is15mShort1 or is15mShort2 or is15mShort3 or is15mShort4 or is15mShort5 or 
    is1hLong1 or is1hLong2 or is1hLong3 or is1hLong4 or is1hLong5 or 
    is1hShort1 or is1hShort2 or is1hShort3 or is1hShort4 or is1hShort5 or 
    is4hLong1 or is4hLong2 or is4hLong3 or is4hLong4 or is4hLong5 or 
