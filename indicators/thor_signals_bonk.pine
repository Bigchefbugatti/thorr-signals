//@version=5
indicator("THOR CALLS - BONK", overlay=true)

// Input for how many bars the boxes should extend
boxLength = input.int(30, title="Box Length (Bars)")

// Function to plot signal boxes and labels
plotSignalBox(entryLow, entryHigh, signalType, timeframeCondition, offsetLevel) =>
    if not na(entryLow) and not na(entryHigh) and timeframeCondition
        var box signalBox = na
        var label signalLabel = na
        
        boxTop = entryHigh
        boxBottom = entryLow
        
        // Create label text with appropriate number formatting
        labelText = signalType + " Entry Zone\n" + (boxTop < 0.001 ? str.tostring(boxTop, "#.##########") : str.tostring(boxTop, "#.######")) + " - " + (boxBottom < 0.001 ? str.tostring(boxBottom, "#.##########") : str.tostring(boxBottom, "#.######"))
        
        // Delete previous box and label
        box.delete(signalBox)
        label.delete(signalLabel)
        
        // Plot new box
        signalBox := box.new(
            left=bar_index,
            top=boxTop,
            right=bar_index + boxLength,
            bottom=boxBottom,
            border_color=signalType == "Long" ? color.green : color.red,
            bgcolor=signalType == "Long" ? color.new(color.green, 90) : color.new(color.red, 90)
        )
        
        // Plot new label
        signalLabel := label.new(
            x=bar_index + boxLength,
            y=boxTop,
            text=labelText,
            color=signalType == "Long" ? color.green : color.red,
            textcolor=signalType == "Long" ? color.green : color.red,
            style=label.style_label_left,
            yloc=yloc.price,
            offset=offsetLevel
        )

// 15m timeframe signals
